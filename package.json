{
  "name": "olympus",
  "productName": "Olympus",
  "version": "0.2.0",
  "description": "Hub desktop des apps internes d'Orphic Agency.",
  "author": "Orphic Agency",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --remote-debugging-port=9223",
    "smoke": "node tools/smoke.js",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.orphicagency.olympus",
    "productName": "Olympus",
    "files": [
      "main.js",
      "preload.js",
      "app-config.json",
      "renderer/**",
      "olympus-mcp/**",
      "medusa-mcp/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null
    },
    "dmg": {
      "title": "Installer Olympus"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "fast-xml-parser": "^5.10.1",
    "ical-generator": "^11.0.0",
    "imapflow": "^1.4.7",
    "node-ical": "^0.27.0",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "tsdav": "^2.3.1"
  }
}
